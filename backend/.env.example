PORT=4000

# GitHub storage — create a fine-grained PAT with Contents: Read+Write on your data repo
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-github-username
GITHUB_REPO=absheron-data
GITHUB_BRANCH=main

# Folder inside the repo where data lives
DATA_PATH=data

# Auth — change these in production
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
JWT_SECRET=replace-with-long-random-string-at-least-32-chars
TOKEN_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins (use * in dev only)
CORS_ORIGIN=http://localhost:5173
